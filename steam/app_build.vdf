"AppBuild"
{
    "AppID"         "XXXXXXX"       // SteamworksでアプリIDを取得後に入力
    "Desc"          "Distortion Observer Build"
    "BuildOutput"   "..\steam_build_output\"

    "Depots"
    {
        "XXXXXXX"   // DepotID（AppID+1が一般的）
        {
            "FileMapping"
            {
                "LocalPath"     "..\dist\DistortionObserver\*"
                "DepotPath"     "."
                "recursive"     "1"
            }
            "FileExclusion"     "*.pdb"
        }
    }
}
